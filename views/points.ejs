<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Points Table</title>
  <style>
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ddd; padding: 8px; text-align: center; }
    th { background-color: #f2f2f2; }
    nav a { margin-right: 1rem; }
  </style>
</head>
<body>
  <h1>Points Table</h1>
  <% if (currentUser) { %>
    <p>Welcome, <%= currentUser.email %>! <a href="/logout">Log out</a></p>
    <nav>
      <a href="/">Matches</a> |
      <a href="/points">Points Table</a> |
      <a href="/scores">Score Cards</a>
      <% if (currentUser.is_admin) { %>|
        <a href="/admin">Admin</a>
      <% } %>
    </nav>
  <% } %>
  <table>
    <tr>
      <th>Rank</th>
      <th>User</th>
      <th>Points</th>
    </tr>
    <% users.forEach(function(user, index) { %>
      <tr>
        <td><%= index + 1 %></td>
        <td><%= user.email %></td>
        <td><%= user.points %></td>
      </tr>
    <% }); %>
  </table>
</body>
</html>
